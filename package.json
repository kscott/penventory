{
	"name": "penventory",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint . --max-warnings 0",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:coverage": "npm run test:unit -- --run --coverage",
		"test:e2e": "playwright install --with-deps chromium && playwright test",
		"test:integration": "vitest --project integration --run",
		"audit": "npm audit --omit=dev --audit-level=high",
		"db:generate": "drizzle-kit generate",
		"db:check-drift": "drizzle-kit generate && test -z \"$(git status --porcelain drizzle/)\""
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/better-sqlite3": "^7.6.13",
		"@types/damerau-levenshtein": "^1.0.2",
		"@types/node": "^24",
		"@vitest/coverage-v8": "^4.1.10",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"better-sqlite3": "^12.11.1",
		"csv-parse": "^7.0.1",
		"damerau-levenshtein": "^1.0.8",
		"drizzle-orm": "^0.45.2",
		"prom-client": "^15.1.3"
	}
}
